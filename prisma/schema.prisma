model workflow_scheduled_instances_queue {
  id                                                                String                       @id
  tenant_id                                                         String
  engagement_service_id                                             String
  company_id                                                        String
  service_definition_id                                             String
  period_label                                                      String                       @db.VarChar(100)
  period_start_date                                                 DateTime?                    @db.Date
  period_end_date                                                   DateTime?                    @db.Date
  proposed_sla_date                                                 DateTime                     @db.Date
  statutory_deadline_date                                           DateTime?                    @db.Date
  proposed_owner_id                                                 String?
  spawn_mode                                                        WorkflowSpawnType            @default(AUTO)
  status                                                            WorkflowScheduledQueueStatus @default(PENDING)
  workflow_instance_id                                              String?
  unique_key                                                        String                       @unique @db.VarChar(255)
  confirmed_by                                                      String?
  confirmed_at                                                      DateTime?
  rejection_reason                                                  String?
  generated_at                                                      DateTime                     @default(now())
  expires_at                                                        DateTime?
  created_at                                                        DateTime                     @default(now())
  updated_at                                                        DateTime
  companies                                                         Company                      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  users_workflow_scheduled_instances_queue_confirmed_byTousers      User?                        @relation("workflow_scheduled_instances_queue_confirmed_byTousers", fields: [confirmed_by], references: [id])
  workflow_engagement_services                                      workflow_engagement_services @relation(fields: [engagement_service_id], references: [id], onDelete: Cascade)
  users_workflow_scheduled_instances_queue_proposed_owner_idTousers User?                        @relation("workflow_scheduled_instances_queue_proposed_owner_idTousers", fields: [proposed_owner_id], references: [id])
  workflow_service_definitions                                      workflow_service_definitions @relation(fields: [service_definition_id], references: [id])
  tenants                                                           Tenant                       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  workflow_instances                                                workflow_instances?          @relation(fields: [workflow_instance_id], references: [id])

  @@index([company_id, status])
  @@index([engagement_service_id, status])
  @@index([tenant_id, status])
}

model workflow_service_definitions {
  id                                 String                               @id
  tenant_id                          String
  name                               String                               @db.VarChar(255)
  description                        String?
  category                           WorkflowServiceCategory
  default_period_type                WorkflowPeriodType
  statutory_deadline_type            String?                              @db.VarChar(100)
  statutory_deadline_notes           String?
  internal_sla_days                  Int?
  risk_level                         WorkflowRiskLevel                    @default(MEDIUM)
  requires_review_milestone          Boolean                              @default(true)
  billing_trigger_milestone_order    Int?
  spawn_lead_days                    Int                                  @default(7)
  is_active                          Boolean                              @default(true)
  version                            Int                                  @default(1)
  created_by                         String
  created_at                         DateTime                             @default(now())
  updated_at                         DateTime
  workflow_engagement_services       workflow_engagement_services[]
  workflow_instances                 workflow_instances[]
  workflow_milestone_templates       workflow_milestone_templates[]
