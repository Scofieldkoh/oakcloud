generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                                 String                               @id @default(uuid())
  name                               String
  slug                               String                               @unique
  status                             TenantStatus                         @default(PENDING_SETUP)
  contactEmail                       String?
  contactPhone                       String?
  settings                           Json?
  maxUsers                           Int                                  @default(50)
  maxCompanies                       Int                                  @default(100)
  maxStorageMb                       Int                                  @default(10240)
  logoUrl                            String?
  primaryColor                       String?                              @default("#294d44")
  createdAt                          DateTime                             @default(now())
  updatedAt                          DateTime                             @updatedAt
  deletedAt                          DateTime?
  deletedReason                      String?
  activatedAt                        DateTime?
  suspendedAt                        DateTime?
  suspendReason                      String?
  aiConversations                    AiConversation[]
  auditLogs                          AuditLog[]
  backupSchedule                     BackupSchedule?
  chartOfAccounts                    ChartOfAccount[]
  companies                          Company[]
  connectorUsageLogs                 ConnectorUsageLog[]
  connectors                         Connector[]
  contactDetails                     ContactDetail[]
  contacts                           Contact[]
  documentTemplates                  DocumentTemplate[]
  documents                          Document[]
  exchangeRates                      ExchangeRate[]
  formFields                         FormField[]
  formDrafts                         FormDraft[]
  formSubmissions                    FormSubmission[]
  formUploads                        FormUpload[]
  forms                              Form[]
  generatedDocuments                 GeneratedDocument[]
  roles                              Role[]
  templatePartials                   TemplatePartial[]
  backups                            TenantBackup[]
  connectorAccess                    TenantConnectorAccess[]
  letterhead                         TenantLetterhead?
  users                              User[]
  workflow_client_groups             workflow_client_groups[]
  workflow_engagements               workflow_engagements[]
  workflow_instances                 workflow_instances[]
  workflow_notification_log          workflow_notification_log[]
  workflow_project_instances         workflow_project_instances[]
  workflow_project_settings          workflow_project_settings[]
  workflow_scheduled_instances_queue workflow_scheduled_instances_queue[]
  workflow_service_definitions       workflow_service_definitions[]

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

model Role {
  id             String               @id @default(uuid())
  tenantId       String?
  name           String
  description    String?
  isSystem       Boolean              @default(false)
  systemRoleType String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  permissions    RolePermission[]
  tenant         Tenant?              @relation(fields: [tenantId], references: [id])
  users          UserRoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([systemRoleType])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid())
  resource    String
  action      String
  description String?
  roles       RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRoleAssignment {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  companyId String?
  createdAt DateTime @default(now())
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, companyId])
  @@index([userId])
  @@index([roleId])
  @@index([companyId])
  @@index([userId, roleId, companyId])
  @@map("user_role_assignments")
}

model User {
  id                                                                                             String                               @id @default(uuid())
  email                                                                                          String                               @unique
  passwordHash                                                                                   String
  firstName                                                                                      String
  lastName                                                                                       String
  isActive                                                                                       Boolean                              @default(true)
  lastLoginAt                                                                                    DateTime?
  createdAt                                                                                      DateTime                             @default(now())
  updatedAt                                                                                      DateTime                             @updatedAt
  deletedAt                                                                                      DateTime?
  mustChangePassword                                                                             Boolean                              @default(false)
  passwordResetToken                                                                             String?                              @unique
  passwordResetExpires                                                                           DateTime?
  passwordChangedAt                                                                              DateTime?
  tenantId                                                                                       String?
  aiConversations                                                                                AiConversation[]                     @relation("ConversationOwner")
  auditLogs                                                                                      AuditLog[]
  connectorUsageLogs                                                                             ConnectorUsageLog[]
  hiddenComments                                                                                 DocumentComment[]                    @relation("CommentHider")
  resolvedComments                                                                               DocumentComment[]                    @relation("CommentResolver")
  authoredComments                                                                               DocumentComment[]                    @relation("CommentAuthor")
  documentDrafts                                                                                 DocumentDraft[]                      @relation("DraftAuthor")
  createdShares                                                                                  DocumentShare[]                      @relation("ShareCreator")
  createdTemplates                                                                               DocumentTemplate[]                   @relation("TemplateCreator")
  uploadedDocuments                                                                              Document[]
  createdDocuments                                                                               GeneratedDocument[]                  @relation("DocumentCreator")
  finalizedDocuments                                                                             GeneratedDocument[]                  @relation("DocumentFinalizer")
  createdPartials                                                                                TemplatePartial[]                    @relation("PartialCreator")
  companyAssignments                                                                             UserCompanyAssignment[]
  preferences                                                                                    UserPreference[]
  roleAssignments                                                                                UserRoleAssignment[]
  tenant                                                                                         Tenant?                              @relation(fields: [tenantId], references: [id])
  workflow_artifacts                                                                             workflow_artifacts[]
  workflow_billing_states                                                                        workflow_billing_states[]
  workflow_blockers_workflow_blockers_owner_idTousers                                            workflow_blockers[]                  @relation("workflow_blockers_owner_idTousers")
  workflow_blockers_workflow_blockers_raised_byTousers                                           workflow_blockers[]                  @relation("workflow_blockers_raised_byTousers")
  workflow_blockers_workflow_blockers_resolved_byTousers                                         workflow_blockers[]                  @relation("workflow_blockers_resolved_byTousers")
  workflow_communication_log_entries                                                             workflow_communication_log_entries[]
  workflow_cross_dependencies                                                                    workflow_cross_dependencies[]
  workflow_deviations                                                                            workflow_deviations[]
  workflow_engagements_workflow_engagements_created_byTousers                                    workflow_engagements[]               @relation("workflow_engagements_created_byTousers")
  workflow_engagements_workflow_engagements_director_poc_idTousers                               workflow_engagements[]               @relation("workflow_engagements_director_poc_idTousers")
  workflow_instances_workflow_instances_assigned_owner_idTousers                                 workflow_instances[]                 @relation("workflow_instances_assigned_owner_idTousers")
  workflow_instances_workflow_instances_cancelled_byTousers                                      workflow_instances[]                 @relation("workflow_instances_cancelled_byTousers")
  workflow_instances_workflow_instances_created_byTousers                                        workflow_instances[]                 @relation("workflow_instances_created_byTousers")
  workflow_milestones_workflow_milestones_completed_byTousers                                    workflow_milestones[]                @relation("workflow_milestones_completed_byTousers")
  workflow_milestones_workflow_milestones_owner_idTousers                                        workflow_milestones[]                @relation("workflow_milestones_owner_idTousers")
  workflow_milestones_workflow_milestones_reviewed_byTousers                                     workflow_milestones[]                @relation("workflow_milestones_reviewed_byTousers")
  workflow_notification_log                                                                      workflow_notification_log[]
  workflow_program_requirements                                                                  workflow_program_requirements[]
  workflow_scheduled_instances_queue_workflow_scheduled_instances_queue_confirmed_byTousers      workflow_scheduled_instances_queue[] @relation("workflow_scheduled_instances_queue_confirmed_byTousers")
  workflow_scheduled_instances_queue_workflow_scheduled_instances_queue_proposed_owner_idTousers workflow_scheduled_instances_queue[] @relation("workflow_scheduled_instances_queue_proposed_owner_idTousers")
  workflow_service_definitions                                                                   workflow_service_definitions[]
  workflow_task_dependencies                                                                     workflow_task_dependencies[]
  workflow_task_items_workflow_task_items_completed_byTousers                                    workflow_task_items[]                @relation("workflow_task_items_completed_byTousers")
  workflow_task_items_workflow_task_items_owner_idTousers                                        workflow_task_items[]                @relation("workflow_task_items_owner_idTousers")

  @@index([email])
  @@index([tenantId])
  @@index([passwordResetToken])
  @@index([tenantId, deletedAt, isActive])
  @@index([deletedAt, isActive])
  @@map("users")
}

model UserPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preferences")
}

model UserCompanyAssignment {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("user_company_assignments")
}

model Company {
  id                                 String                               @id @default(uuid())
  tenantId                           String
  uen                                String
  name                               String
  formerName                         String?
  dateOfNameChange                   DateTime?
  entityType                         EntityType                           @default(PRIVATE_LIMITED)
  status                             CompanyStatus                        @default(LIVE)
  statusDate                         DateTime?
  incorporationDate                  DateTime?
  registrationDate                   DateTime?
  dateOfAddress                      DateTime?
  primarySsicCode                    String?
  primarySsicDescription             String?
  secondarySsicCode                  String?
  secondarySsicDescription           String?
  financialYearEndDay                Int?
  financialYearEndMonth              Int?
  fyeAsAtLastAr                      DateTime?
  homeCurrency                       String?                              @default("SGD")
  lastAgmDate                        DateTime?
  lastArFiledDate                    DateTime?
  nextAgmDueDate                     DateTime?
  nextArDueDate                      DateTime?
  accountsDueDate                    DateTime?
  paidUpCapitalCurrency              String?                              @default("SGD")
  paidUpCapitalAmount                Decimal?                             @db.Decimal(18, 2)
  issuedCapitalCurrency              String?                              @default("SGD")
  issuedCapitalAmount                Decimal?                             @db.Decimal(18, 2)
  hasCharges                         Boolean                              @default(false)
  isGstRegistered                    Boolean                              @default(false)
  gstRegistrationNumber              String?
  gstRegistrationDate                DateTime?
  isRegisteredCharity                Boolean                              @default(false)
  charityRegistrationDate            DateTime?
  charityUEN                         String?
  isIPC                              Boolean                              @default(false)
  ipcEffectiveDate                   DateTime?
  ipcExpiryDate                      DateTime?
  annualReceiptsOrExpenditure        Decimal?                             @db.Decimal(18, 2)
  createdAt                          DateTime                             @default(now())
  updatedAt                          DateTime                             @updatedAt
  deletedAt                          DateTime?
  deletedReason                      String?
  auditLogs                          AuditLog[]
  chartOfAccounts                    ChartOfAccount[]
  accountMappings                    ChartOfAccountsMapping[]
  tenant                             Tenant                               @relation(fields: [tenantId], references: [id])
  addresses                          CompanyAddress[]
  charges                            CompanyCharge[]
  contacts                           CompanyContact[]
  formerNames                        CompanyFormerName[]
  officers                           CompanyOfficer[]
  shareholders                       CompanyShareholder[]
  contactDetails                     ContactDetail[]
  documentTags                       DocumentTag[]
  documents                          Document[]
  generatedDocuments                 GeneratedDocument[]
  noteTabs                           NoteTab[]
  shareCapital                       ShareCapital[]
  userAssignments                    UserCompanyAssignment[]
  roleAssignments                    UserRoleAssignment[]
  workflow_client_group_members      workflow_client_group_members[]
  workflow_engagements               workflow_engagements[]
  workflow_instances                 workflow_instances[]
  workflow_project_instances         workflow_project_instances[]
  workflow_project_settings          workflow_project_settings?
  workflow_scheduled_instances_queue workflow_scheduled_instances_queue[]

  @@unique([tenantId, uen])
  @@index([tenantId])
  @@index([uen])
  @@index([name])
  @@index([status])
  @@index([entityType])
  @@index([tenantId, deletedAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([nextArDueDate])
  @@index([status, nextArDueDate])
  @@index([tenantId, status])
  @@map("companies")
}

model CompanyFormerName {
  id               String    @id @default(uuid())
  companyId        String
  formerName       String
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  sourceDocumentId String?
  createdAt        DateTime  @default(now())
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document         Document? @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId])
  @@map("company_former_names")
}

model CompanyAddress {
  id               String      @id @default(uuid())
  companyId        String
  addressType      AddressType
  block            String?
  streetName       String
  level            String?
  unit             String?
  buildingName     String?
  postalCode       String
  country          String      @default("SINGAPORE")
  fullAddress      String
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  isCurrent        Boolean     @default(true)
  sourceDocumentId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document         Document?   @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId])
  @@index([addressType])
  @@index([isCurrent])
  @@index([companyId, isCurrent])
  @@index([companyId, isCurrent, addressType])
  @@map("company_addresses")
}

model Contact {
  id                                 String                               @id @default(uuid())
  tenantId                           String
  contactType                        ContactType                          @default(INDIVIDUAL)
  firstName                          String?
  lastName                           String?
  fullName                           String
  alias                              String?
  identificationType                 IdentificationType?
  identificationNumber               String?
  nationality                        String?
  dateOfBirth                        DateTime?
  corporateName                      String?
  corporateUen                       String?
  fullAddress                        String?
  isActive                           Boolean                              @default(true)
  createdAt                          DateTime                             @default(now())
  updatedAt                          DateTime                             @updatedAt
  deletedAt                          DateTime?
  chargeHoldings                     CompanyCharge[]
  companyRelations                   CompanyContact[]
  officerPositions                   CompanyOfficer[]
  shareholdings                      CompanyShareholder[]
  contactDetails                     ContactDetail[]
  tenant                             Tenant                               @relation(fields: [tenantId], references: [id])
  noteTabs                           NoteTab[]
  workflow_communication_log_entries workflow_communication_log_entries[]
  workflow_milestones                workflow_milestones[]

  @@unique([tenantId, identificationType, identificationNumber])
  @@index([tenantId])
  @@index([fullName])
  @@index([identificationNumber])
  @@index([corporateUen])
  @@index([tenantId, deletedAt])
  @@map("contacts")
}

model CompanyContact {
  id           String    @id @default(uuid())
  companyId    String
  contactId    String
  relationship String
  isPrimary    Boolean   @default(false)
  isPoc        Boolean   @default(false)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId, relationship])
  @@index([companyId])
  @@index([contactId])
  @@index([deletedAt])
  @@map("company_contacts")
}

model ContactDetail {
  id           String            @id @default(uuid())
  tenantId     String
  contactId    String?
  companyId    String?
  detailType   ContactDetailType
  value        String
  label        String?
  purposes     String[]          @default([])
  description  String?
  displayOrder Int               @default(0)
  isPrimary    Boolean           @default(false)
  isPoc        Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?
  company      Company?          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact      Contact?          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tenant       Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([contactId])
  @@index([companyId])
  @@index([detailType])
  @@index([tenantId, contactId])
  @@index([tenantId, companyId])
  @@index([tenantId, deletedAt])
  @@map("contact_details")
}

model CompanyOfficer {
  id                   String              @id @default(uuid())
  companyId            String
  contactId            String?
  role                 OfficerRole
  name                 String
  identificationType   IdentificationType?
  identificationNumber String?
  nationality          String?
  address              String?
  appointmentDate      DateTime?
  cessationDate        DateTime?
  isCurrent            Boolean             @default(true)
  sourceDocumentId     String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact              Contact?            @relation(fields: [contactId], references: [id])
  document             Document?           @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@index([role])
  @@index([isCurrent])
  @@index([companyId, isCurrent])
  @@index([contactId, companyId])
  @@index([name, isCurrent])
  @@index([companyId, isCurrent, appointmentDate])
  @@map("company_officers")
}

model ShareCapital {
  id               String    @id @default(uuid())
  companyId        String
  shareClass       String    @default("ORDINARY")
  currency         String    @default("SGD")
  numberOfShares   Int
  parValue         Decimal?  @db.Decimal(18, 4)
  totalValue       Decimal   @db.Decimal(18, 2)
  isPaidUp         Boolean   @default(true)
  isTreasury       Boolean   @default(false)
  effectiveDate    DateTime?
  sourceDocumentId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  company          Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document         Document? @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId])
  @@map("share_capital")
}

model CompanyShareholder {
  id                   String              @id @default(uuid())
  companyId            String
  contactId            String?
  name                 String
  shareholderType      ContactType         @default(INDIVIDUAL)
  identificationType   IdentificationType?
  identificationNumber String?
  nationality          String?
  placeOfOrigin        String?
  address              String?
  shareClass           String              @default("ORDINARY")
  numberOfShares       Int
  percentageHeld       Decimal?            @db.Decimal(5, 2)
  currency             String              @default("SGD")
  allotmentDate        DateTime?
  transferDate         DateTime?
  isCurrent            Boolean             @default(true)
  sourceDocumentId     String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact              Contact?            @relation(fields: [contactId], references: [id])
  document             Document?           @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@index([isCurrent])
  @@index([companyId, isCurrent])
  @@index([contactId, companyId])
  @@index([name, isCurrent])
  @@index([companyId, isCurrent, numberOfShares])
  @@map("company_shareholders")
}

model CompanyCharge {
  id                String    @id @default(uuid())
  companyId         String
  chargeHolderId    String?
  chargeNumber      String?
  chargeType        String?
  description       String?
  chargeHolderName  String
  amountSecured     Decimal?  @db.Decimal(18, 2)
  amountSecuredText String?
  currency          String?   @default("SGD")
  registrationDate  DateTime?
  dischargeDate     DateTime?
  isFullyDischarged Boolean   @default(false)
  sourceDocumentId  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  chargeHolder      Contact?  @relation(fields: [chargeHolderId], references: [id])
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document          Document? @relation(fields: [sourceDocumentId], references: [id])

  @@index([companyId])
  @@index([chargeHolderId])
  @@index([isFullyDischarged])
  @@index([companyId, isFullyDischarged, registrationDate])
  @@map("company_charges")
}

model Document {
  id                 String               @id @default(uuid())
  tenantId           String
  companyId          String?
  uploadedById       String
  documentType       String
  fileName           String
  originalFileName   String
  storageKey         String               @map("storage_key")
  fileSize           Int
  mimeType           String
  extractedAt        DateTime?
  extractionStatus   String?              @default("PENDING")
  extractionError    String?
  extractedData      Json?
  version            Int                  @default(1)
  isLatest           Boolean              @default(true)
  previousVersionId  String?
  deletedAt          DateTime?            @map("deleted_at")
  deletedReason      String?              @map("deleted_reason")
  deletedById        String?              @map("deleted_by_id")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  addresses          CompanyAddress[]
  charges            CompanyCharge[]
  formerNames        CompanyFormerName[]
  officers           CompanyOfficer[]
  shareholders       CompanyShareholder[]
  company            Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  uploadedBy         User                 @relation(fields: [uploadedById], references: [id])
  processingDocument ProcessingDocument?
  shareCapital       ShareCapital[]
  workflow_artifacts workflow_artifacts[]

  @@index([tenantId])
  @@index([companyId])
  @@index([documentType])
  @@index([uploadedById])
  @@index([tenantId, companyId])
  @@index([tenantId, deletedAt])
  @@index([companyId, isLatest, createdAt])
  @@map("documents")
}

model AuditLog {
  id           String       @id @default(uuid())
  tenantId     String?
  userId       String?
  companyId    String?
  action       AuditAction
  entityType   String
  entityId     String
  changeSource ChangeSource @default(MANUAL)
  changes      Json?
  reason       String?
  summary      String?
  entityName   String?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  requestId    String?
  sessionId    String?
  createdAt    DateTime     @default(now())
  company      Company?     @relation(fields: [companyId], references: [id])
  tenant       Tenant?      @relation(fields: [tenantId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([companyId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([tenantId, entityType])
  @@index([requestId])
  @@map("audit_logs")
}

model Connector {
  id             String                  @id @default(uuid())
  tenantId       String?
  name           String
  type           ConnectorType
  provider       ConnectorProvider
  credentials    String
  settings       Json?
  isEnabled      Boolean                 @default(true)
  isDefault      Boolean                 @default(false)
  callCount      Int                     @default(0)
  lastUsedAt     DateTime?
  lastTestedAt   DateTime?
  lastTestResult String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?
  modelConfigs   ConnectorModelConfig[]
  usageLogs      ConnectorUsageLog[]
  tenant         Tenant?                 @relation(fields: [tenantId], references: [id])
  tenantAccess   TenantConnectorAccess[]

  @@unique([tenantId, provider, deletedAt])
  @@index([tenantId])
  @@index([type])
  @@index([provider])
  @@index([isEnabled])
  @@index([deletedAt])
  @@map("connectors")
}

model TenantConnectorAccess {
  id          String    @id @default(uuid())
  tenantId    String
  connectorId String
  isEnabled   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  connector   Connector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, connectorId])
  @@index([tenantId])
  @@index([connectorId])
  @@map("tenant_connector_access")
}

model ConnectorUsageLog {
  id           String    @id @default(uuid())
  connectorId  String
  tenantId     String?
  userId       String?
  model        String
  provider     String
  inputTokens  Int       @default(0)
  outputTokens Int       @default(0)
