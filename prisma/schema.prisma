  workflow_task_items_workflow_task_dependencies_successor_task_idToworkflow_task_items   workflow_task_items @relation("workflow_task_dependencies_successor_task_idToworkflow_task_items", fields: [successor_task_id], references: [id], onDelete: Cascade)

  @@unique([predecessor_task_id, successor_task_id])
  @@index([successor_task_id])
}

model workflow_task_items {
  id                                                                                               String                        @id
  milestone_id                                                                                     String
  task_template_id                                                                                 String?
  name                                                                                             String                        @db.VarChar(500)
  description                                                                                      String?
  is_required                                                                                      Boolean                       @default(false)
  display_order                                                                                    Int
  status                                                                                           WorkflowTaskItemStatus        @default(OPEN)
  completed_by                                                                                     String?
  completed_at                                                                                     DateTime?
  created_at                                                                                       DateTime                      @default(now())
  updated_at                                                                                       DateTime
  owner_id                                                                                         String?
  due_date                                                                                         DateTime?                     @db.Date
  estimated_minutes                                                                                Int?
  actual_minutes                                                                                   Int?
  automation_rule_code                                                                             String?
  automation_config                                                                                Json?
  workflow_artifacts                                                                               workflow_artifacts[]
  workflow_cross_dependencies_workflow_cross_dependencies_predecessor_task_idToworkflow_task_items workflow_cross_dependencies[] @relation("workflow_cross_dependencies_predecessor_task_idToworkflow_task_items")
  workflow_cross_dependencies_workflow_cross_dependencies_successor_task_idToworkflow_task_items   workflow_cross_dependencies[] @relation("workflow_cross_dependencies_successor_task_idToworkflow_task_items")
  workflow_task_dependencies_workflow_task_dependencies_predecessor_task_idToworkflow_task_items   workflow_task_dependencies[]  @relation("workflow_task_dependencies_predecessor_task_idToworkflow_task_items")
  workflow_task_dependencies_workflow_task_dependencies_successor_task_idToworkflow_task_items     workflow_task_dependencies[]  @relation("workflow_task_dependencies_successor_task_idToworkflow_task_items")
  users_workflow_task_items_completed_byTousers                                                    User?                         @relation("workflow_task_items_completed_byTousers", fields: [completed_by], references: [id])
  workflow_milestones                                                                              workflow_milestones           @relation(fields: [milestone_id], references: [id], onDelete: Cascade)
  users_workflow_task_items_owner_idTousers                                                        User?                         @relation("workflow_task_items_owner_idTousers", fields: [owner_id], references: [id])
  workflow_task_templates                                                                          workflow_task_templates?      @relation(fields: [task_template_id], references: [id])

  @@unique([milestone_id, display_order])
  @@index([due_date])
  @@index([milestone_id, status])
  @@index([owner_id])
}

model workflow_task_templates {
  id                           String                       @id
  milestone_template_id        String
  name                         String                       @db.VarChar(500)
  description                  String?
  is_required                  Boolean                      @default(false)
  display_order                Int
  created_at                   DateTime                     @default(now())
  automation_rule_code         String?
